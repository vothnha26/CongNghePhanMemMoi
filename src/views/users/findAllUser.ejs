<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>List Users</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@4.6.2/dist/css/bootstrap.min.css">
</head>
<body>
<div class="container">
    <div class="row">
        <div class="col-12 mt-3">
            <h2>List users</h2>
            <table class="table table-bordered">
                <thead>
                  <tr>
                    <th>Email</th>
                    <th>First Name</th>
                    <th>Last Name</th>
                    <th>Address</th>
                    <th>Action</th>
                  </tr>
                </thead>
                <tbody>
                  <% for(let i=0; i < datalist.length; i++) { %>
                  <tr>
                    <td><%= datalist[i].email %></td>
                    <td><%= datalist[i].firstName %></td>
                    <td><%= datalist[i].lastName %></td>
                    <td><%= datalist[i].address %></td>
                    <td>
                      <a href="/edit-crud?id=<%= datalist[i].id %>" class="btn btn-warning">Edit</a>
                      <a href="/delete-crud?id=<%= datalist[i].id %>" class="btn btn-danger" onclick="return confirm('Are you sure?')">Delete</a>
                    </td>
                  </tr>
                  <% } %>
                </tbody>
              </table>
              <a href="/crud" class="btn btn-primary">Create new user</a>
        </div>
    </div>
</div>
</body>
</html>
